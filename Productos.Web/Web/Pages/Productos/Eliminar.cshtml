@page
@model Web.Pages.Productos.EliminarModel
@{
}

<h1>Eliminar Producto</h1>

<div class="container">
    <form method="post">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">

                    <h5 class="card-title">
                        @Html.DisplayFor(modelo => modelo.Producto.Nombre)
                    </h5>

                    <p class="text-muted">
                        Categoría:
                        @Html.DisplayFor(modelo => modelo.Producto.Categoria)
                        |
                        SubCategoría:
                        @Html.DisplayFor(modelo => modelo.Producto.SubCategoria)
                    </p>
                    <div>
                        <b>@Html.DisplayNameFor(modelo => modelo.Producto.Descripcion):</b>
                        @Html.DisplayFor(modelo => modelo.Producto.Descripcion)
                    </div>
                    <div>
                        <b>@Html.DisplayNameFor(modelo => modelo.Producto.Precio):</b>
                        $@Html.DisplayFor(modelo => modelo.Producto.Precio)
                    </div>
                    <div>
                        <b>@Html.DisplayNameFor(modelo => modelo.Producto.Stock):</b>
                        @Html.DisplayFor(modelo => modelo.Producto.Stock)
                    </div>
                    <div>
                        <b>@Html.DisplayNameFor(modelo => modelo.Producto.CodigoBarras):</b>
                        @Html.DisplayFor(modelo => modelo.Producto.CodigoBarras)
                    </div>

                </div>

            </div>

        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-danger">Eliminar </button>

            <a class="btn btn-primary" asp-page="./Index">Regresar</a>
        </div>
    </form>

</div>